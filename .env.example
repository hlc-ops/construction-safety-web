# 复制本文件为 .env 并填入真实值。.env 不要提交到代码库。

# ---- 视觉大模型（YOLO 二次复核 + AI 智能日报 + 告警分级）----
# provider: qwen（通义千问，默认）/ zhipu（智谱 GLM-4V）
LLM_PROVIDER=qwen
LLM_API_KEY=
# 可选：覆盖默认视觉模型 / 接口地址
# LLM_MODEL=qwen-vl-plus
# LLM_BASE_URL=
# 可选：覆盖文本模型（用于 AI 日报）
# LLM_TEXT_MODEL=qwen-plus

# ---- 可选：安全密钥（生产环境务必改）----
# SECRET_KEY=
# JWT_SECRET_KEY=

# ---- 可选：报警推送 Webhook ----
# ALERT_DINGTALK_WEBHOOK=
# ALERT_WECOM_WEBHOOK=
